{
  "manifest_version": 3,
  "name": "ZKP Share Cookie Injector",
  "version": "1.2.0",
  "permissions": ["cookies", "tabs", "storage", "scripting", "webNavigation"],
  "host_permissions": [
    "http://localhost:8001/*",
    "https://recolyse.com/*"
  ],
  "action": {
    "default_title": "Inject cookies from ZKP share",
    "default_popup": "popup.html",
    "default_icon": "icon32.png"
  },
  "icons": {
    "32": "icon32.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}